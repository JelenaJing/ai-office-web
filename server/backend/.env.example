# ── 统一 LLM（Idea + 模板画图，与 Express ai-gateway 同一套规则）────────────
# 官方文档：https://help.aliyun.com/zh/model-studio/developer-reference/use-qwen-by-calling-api
# 控制台密钥：https://dashscope.console.aliyun.com/apiKey
LLM_PROVIDER=qwen

# 可选：显式覆盖（不填则使用 QWEN_API_KEY + build/ai-config.json 默认地址/模型）
# LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max

# 通义千问 DashScope（OpenAI 兼容模式）
QWEN_API_KEY=your_dashscope_api_key_here

# 常用模型（按需改 LLM_MODEL）：qwen-max | qwen-plus | qwen-turbo | qwen-long

# DeepSeek 已停用（勿配置）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# OpenAlex配置（用于搜索学术论文）
# 可选，但建议设置以提升API限制
OPENALEX_EMAIL=your_email@example.com

# 旧 Plot Agent 配置
# 现有主流程已内置绘图服务；该变量仅为兼容旧代码保留
PLOT_AGENT_URL=http://localhost:8001

# DeepSyn App 配置
# 实验可视化 / 机器配方链路会访问这个服务
DEEPSYN_API_URL=http://localhost:5002

# grsai-draw-gateway 配置（由后端进程访问：与本机同机用 127.0.0.1；网关在别机则填 http://<host>:<port>）
# 参考 /home/ywt/w/grsai-draw-gateway 的 README.md；启动后访问 http://127.0.0.1:<PORT>/docs
DRAW_GATEWAY_BASE_URL=http://127.0.0.1:42000
# 生成图片最长等待（秒），超时后仍可用 task_id 继续轮询
DRAW_GATEWAY_TIMEOUT_SECONDS=300
# 轮询间隔（秒）
DRAW_GATEWAY_POLL_INTERVAL_SECONDS=3

# 数据目录配置（可选）
# 默认存储在仓库根目录 data/projects/
# PAPER_REMAKE_DATA_DIR=/path/to/your/data/dir

# 日志级别（可选）
# LOG_LEVEL=INFO
