{
  "name": "aios-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=.env.local ts-node-dev -r dotenv/config --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "DOTENV_CONFIG_PATH=.env.local node -r dotenv/config dist/index.js",
    "start:minimax": "PPT_ENGINE=minimax_pptx_generator PPT_ENGINE_FALLBACK=builtin DOTENV_CONFIG_PATH=.env.local node -r dotenv/config dist/index.js",
    "start:minimax-strict": "PPT_ENGINE=minimax_pptx_generator PPT_ENGINE_FALLBACK=none DOTENV_CONFIG_PATH=.env.local node -r dotenv/config dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "slidev:install": "cd slidev-runtime && npm install --no-audit --no-fund",
    "dev:research-lab": "cd dev/research-lab && npm install --no-audit --no-fund && npm run dev",
    "dev:research-frontend-test": "cd dev/research-frontend-test && npm install --no-audit --no-fund && npm run dev",
    "setup:research-conda": "bash dev/setup-research-conda.sh",
    "sync:research-test-env": "bash dev/sync-research-test-env.sh",
    "dev:research-test-stack": "bash dev/start-research-test-stack.sh",
    "stop:research-test-stack": "bash dev/stop-research-test-stack.sh",
    "smoke:research-idea-plot:test-ports": "RESEARCH_SMOKE_BFF_BASE=http://127.0.0.1:13001 PAPER_REMAKE_BASE_URL=http://127.0.0.1:18020 RESEARCH_SMOKE_SKIP_IDEA=1 npm run smoke:research-idea-plot",
    "smoke:research-idea-plot": "DOTENV_CONFIG_PATH=.env.local ts-node -r dotenv/config scripts/smoke/research-idea-plot-smoke.ts",
    "smoke:sciencerelay-reco": "ts-node scripts/smoke/sciencerelay-reco-smoke.ts",
    "sync:sciencerelay-data": "bash dev/sync-sciencerelay-data.sh",
    "smoke:document-studio": "DOTENV_CONFIG_PATH=.env.local DOCUMENT_STUDIO_SMOKE_START_SERVER=1 ts-node -r dotenv/config scripts/smoke/document-studio-smoke.ts",
    "smoke:document-studio-opencode": "DOTENV_CONFIG_PATH=.env.local DOCUMENT_STUDIO_SMOKE_START_SERVER=1 ts-node -r dotenv/config scripts/smoke/document-studio-opencode-smoke.ts",
    "smoke:document-studio-humanizer": "DOTENV_CONFIG_PATH=.env.local DOCUMENT_STUDIO_SMOKE_START_SERVER=1 ts-node -r dotenv/config scripts/smoke/document-studio-humanizer-smoke.ts",
    "check:markitdown": "ts-node scripts/check-markitdown.ts",
    "skills:install-document-studio": "bash scripts/install-document-studio-skills.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "http-proxy": "^1.18.1",
    "imapflow": "^1.3.3",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.8",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pptxgenjs": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/http-proxy": "^1.17.15",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "@slidev/cli": "^0.49.29"
  }
}
