// Rename this file to .env.local for local dev (server npm run dev loads .env.local automatically).
// Copy: cp .env.example .env.local

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/aios_dev?schema=public"

# Secret key for signing JWT tokens — change this before deploying!
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# Port the server listens on
PORT=3001

# ── AI Gateway (server-side only — never commit .env.local) ───────────────────
# Provider: openai | qwen | deepseek | cuhk | custom
# If unset, uses build/ai-config.json → llm.active
LLM_PROVIDER=qwen

# Optional explicit overrides (highest priority)
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# Provider-specific API keys (used when LLM_API_KEY is not set)
QWEN_API_KEY=
DEEPSEEK_API_KEY=
CUHK_API_KEY=
OPENAI_API_KEY=
