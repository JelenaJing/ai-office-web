// Rename this file to .env.local for local dev (server npm run dev loads .env.local automatically).
// Copy: cp .env.example .env.local

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/aios_dev?schema=public"

# Secret key for signing JWT tokens — change this before deploying!
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# Port the server listens on
PORT=3001

# Internal AccountCenter upstream (server-side only)
ACCOUNT_CENTER_BASE_URL=http://127.0.0.1:13100

# ── AI Gateway (server-side only — never commit .env.local) ───────────────────
# Provider: openai | qwen | deepseek | cuhk | custom
# If unset, uses build/ai-config.json → llm.active
LLM_PROVIDER=qwen

# Optional explicit overrides (highest priority)
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# Provider-specific API keys (used when LLM_API_KEY is not set)
QWEN_API_KEY=
DEEPSEEK_API_KEY=
CUHK_API_KEY=
OPENAI_API_KEY=

# ── Auth rate limiting (development) ─────────────────────────────────────────
# Default in non-production: 200 requests / 15 min (generous for dev)
# Default in production:      10 requests / 15 min (brute-force protection)
#
# Uncomment one or more of the following when iterating locally:
#
# Skip auth rate limit entirely (dev only — never use in production):
# RATE_LIMIT_AUTH_DISABLED=true
#
# Skip auth rate limit for localhost / 127.0.0.1 / ::1 (safer than disabling globally):
RATE_LIMIT_AUTH_SKIP_LOCALHOST=true
#
# Override max requests per window (e.g. set to 3 to test that limiting still works):
# RATE_LIMIT_AUTH_MAX=200
#
# Override window length in milliseconds (default: 900000 = 15 min):
# RATE_LIMIT_AUTH_WINDOW_MS=900000

# ─── PPT Engine ──────────────────────────────────────────────────────────────
# Default engine for PPT generation.
# 'minimax_pptx_generator': LLM generates PptxGenJS slide files per MiniMax skill spec (default)
# 'builtin': simpler built-in generator using simplePptx.ts
PPT_ENGINE=minimax_pptx_generator
# What to do when minimax_pptx_generator fails:
# 'builtin': fall back to built-in generator (recommended for production)
# 'none': fail the task with an error (useful to surface issues during testing)
PPT_ENGINE_FALLBACK=builtin
