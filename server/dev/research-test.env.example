# Research 测试栈专用环境（勿提交含密钥的 research-test.env）
#
# 用法（在 ai-office-web/server 目录下执行，不要再 cd ai-office-web/server）:
#   cp dev/research-test.env.example dev/research-test.env
#   # 方式 A：在下方填写 QWEN_API_KEY 等
#   # 方式 B：留空 Key，启动脚本会自动从 server/.env.local 读取 LLM
#   npm run dev:research-test-stack
#
# 或与端口文件一起加载:
#   cp dev/research-test.ports.env.example dev/research-test.ports.env

# ── 测试端口（与主站 3001/8020/5173 隔离）────────────────────────────────────
RESEARCH_TEST_FASTAPI_PORT=18020
RESEARCH_TEST_BFF_PORT=13001
RESEARCH_TEST_UI_PORT=25176
RESEARCH_CONDA_ENV=aios-research-backend
PAPER_REMAKE_BASE_URL=http://127.0.0.1:18020

# ── 统一 LLM（与 server/.env.local、build/ai-config.json 规则一致）──────────
# 可与主站 .env.local 填相同值；测试栈启动脚本会注入到 FastAPI 子进程
LLM_PROVIDER=qwen
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
QWEN_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# Idea 论文检索（FastAPI OpenAlex）
OPENALEX_EMAIL=zealwongmail1@2925.com

# BFF 长任务超时（默认 10 分钟；预览模式下单次 Idea 通常 <2 分钟）
RESEARCH_SKILL_TIMEOUT_MS=600000

# FastAPI：上传 PDF 后 Idea 仅用原文前 N 字，跳过 LLM 清洗与分段（0=关闭）
IDEA_PAPER_MAX_CHARS=1000

# Idea 生成条数（默认 10）；OpenAlex 文献池大小（默认 25）
IDEA_GENERATION_COUNT=10
OPENALEX_IDEA_POOL_SIZE=25

# ── Science Relay 期刊数据（只读，供 AI for Science 测试版主页推荐）────────────
# 远端目录会更新，建议启动前同步到本地镜像，并缩短缓存 TTL。
# 方式 A：rsync 到本地目录（推荐，manifest + articles 会随远端更新）
# 启动时从远端 rsync（路径相对 server/ 目录）；远端更新后重启栈或点 UI「刷新最新」
SCIENCERELAY_SYNC_ON_START=1
# 同步整个静态站；BFF 会自动识别 data/articles-manifest.json
SCIENCERELAY_SYNC_SOURCE=ywt@10.26.1.25:/data/ywt/ai-class/public/sciencerelay/
SCIENCERELAY_LOCAL_MIRROR=dev/.cache/sciencerelay-remote
SCIENCERELAY_DATA_DIR=dev/.cache/sciencerelay-remote
# 无 SSH 时可用内置小样：SCIENCERELAY_DATA_DIR=dev/test-fixtures/sciencerelay-mini
SCIENCERELAY_DATA_SOURCE_MODE=local
# manifest 内存缓存 TTL；本地模式下还会对比 articles-manifest.json 的 mtime，有更新即重载
SCIENCERELAY_CACHE_TTL_MS=30000
# 可选：HTTP 拉取（需远端静态服务可访问 manifest/articles）
# SCIENCERELAY_DATA_HTTP_BASE=https://10.26.1.25/ai-class/public/sciencerelay
# SCIENCERELAY_DATA_SOURCE_MODE=http

# ── 说明（勿在此文件配置生图）────────────────────────────────────────────────
# • Research 模板作图 = matplotlib，不需要 IMAGE_* / DRAW_GATEWAY_*
# • 主站 AI 生图: server/.env.local 的 IMAGE_ENDPOINT / IMAGE_API_KEY
# • Remake Domain 生图: backend DRAW_GATEWAY_*（非 Research 测试范围）
