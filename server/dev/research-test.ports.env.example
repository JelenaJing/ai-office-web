# Research 测试版专用端口（复制为 research-test.ports.env 后 source，或写入各子项目 .env.local）
#
# Python（conda，见 dev/setup-research-conda.sh）：
# RESEARCH_CONDA_ENV=aios-research-backend
#
# 主站常用（勿与测试版混用）：
#   Express 3001 | 主 Web Vite 5173 | Paper Remake 8020 | Legacy UI 8021
#
# 测试版默认：
RESEARCH_TEST_LAB_PORT=25175          # research-lab 简易调试 UI
RESEARCH_TEST_UI_PORT=25176            # research-frontend-test 科研工作台测试版
RESEARCH_TEST_BFF_PORT=13001           # Express（需 PORT=13001 npm run dev）
RESEARCH_TEST_FASTAPI_PORT=18020       # uvicorn paper-remake 后端

# Vite 代理目标（research-lab / research-frontend-test 的 .env.local）
VITE_API_BASE=http://127.0.0.1:13001
VITE_PAPER_REMAKE_BASE=http://127.0.0.1:18020

# Express 连测试 FastAPI 时（server/.env.local 可选）
# PORT=13001
# PAPER_REMAKE_BASE_URL=http://127.0.0.1:18020
