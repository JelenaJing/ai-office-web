{
  "id": "general-document-writer",
  "name": "通用文稿生成",
  "description": "根据用户需求生成通用文稿初稿",
  "category": "document-generation",
  "runner": "opencode",
  "entryFile": "SKILL.md",
  "version": "1.0.0",
