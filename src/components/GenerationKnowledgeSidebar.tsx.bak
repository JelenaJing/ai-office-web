type PreviewableKnowledgeDocument = KnowledgeDocumentMeta & {
  thumbnailPath?: string
  thumbnailRelativePath?: string
  originalPath?: string
  originalRelativePath?: string
}

function formatImageReferenceRoleLabel(role: ImageReferenceRole | null): string {
  if (role === 'primary-style') return '主参考图'
  if (role === 'style') return '风格参考图'
  if (role === 'content') return '内容参考图'
  return '可用图片素材'
}

function formatImageCardRoleLabel(mode: 'image' | 'ppt', role: ImageReferenceRole | null): string {
  if (mode === 'image') return formatImageReferenceRoleLabel(role)
  if (role === 'primary-style') return '主素材'
  if (role) return '本轮素材'
  return '可用素材'
}

interface ImageMaterialCardProps {
  document: PreviewableKnowledgeDocument
  mode: 'image' | 'ppt'
  rootPath?: string
  referenceRole: ImageReferenceRole | null
  referenceWeight?: number
  onOpenDocument: (document: KnowledgeDocumentMeta) => void
  onOpenPreview: (document: KnowledgeDocumentMeta) => void
  onSetPrimary: (document: KnowledgeDocumentMeta) => void
  onSetStyleReference: (document: KnowledgeDocumentMeta) => void
  onSetContentReference: (document: KnowledgeDocumentMeta) => void
  onClearReference: (document: KnowledgeDocumentMeta) => void
  onDelete: (document: KnowledgeDocumentMeta) => void
}

function resolveKnowledgeAssetPath(rootPath: string | undefined, candidate?: string): string {
  const value = String(candidate || '').trim()
  if (!value) return ''
  if (/^(https?:)?\/\//i.test(value) || value.startsWith('data:') || value.startsWith('file:///')) return value
  if (value.startsWith('/')) return value
  const base = String(rootPath || '').replace(/[\\/]+$/g, '')
  return base ? `${base}/${value.replace(/^[\\/]+/g, '')}` : value
}

function resolveKnowledgeThumbnailPath(rootPath: string | undefined, document: PreviewableKnowledgeDocument): string {
  return resolveKnowledgeAssetPath(rootPath, document.thumbnailPath)
    || resolveKnowledgeAssetPath(rootPath, document.thumbnailRelativePath)
    || resolveKnowledgeAssetPath(rootPath, document.storedRelativePath)
}

function resolveKnowledgeOriginalPath(rootPath: string | undefined, document: PreviewableKnowledgeDocument): string {
  return resolveKnowledgeAssetPath(rootPath, document.originalPath)
    || resolveKnowledgeAssetPath(rootPath, document.originalRelativePath)
    || resolveKnowledgeAssetPath(rootPath, document.storedRelativePath)
}

function ImageMaterialCard({
  document,
  mode,
  rootPath,
  referenceRole,
  referenceWeight,
  onOpenDocument,
  onOpenPreview,
  onSetPrimary,
  onSetStyleReference,
  onSetContentReference,
  onClearReference,
  onDelete,
}: ImageMaterialCardProps) {
  const [thumbFailed, setThumbFailed] = useState(false)
  const thumbnailUrl = !thumbFailed ? toDisplayUrl(resolveKnowledgeThumbnailPath(rootPath, document)) : ''
  const isPrimary = referenceRole === 'primary-style'
  const isSelected = Boolean(referenceRole)
  const helperText = mode === 'image'
    ? referenceRole === 'primary-style'
      ? '先预览，再决定是否继续把其他图片加入风格参考。当前这张图正在主导整体画风。'
      : referenceRole === 'style'
        ? '这张图已加入风格参考，会补充视觉语言，但不会压过主参考图。'
        : referenceRole === 'content'
          ? '这张图当前保留为内容参考。你也可以把它直接转成风格参考。'
          : '先预览，再决定是把它设为主参考图还是加入风格参考。'
    : referenceRole === 'primary-style'
      ? '这张图片会作为本轮 PPT 生成的主素材。'
      : isSelected
        ? '这张图片已加入本轮 PPT 素材池。'
        : '可以先预览，再决定是否加入本轮。'

  const imageStyleActionLabel = referenceRole === 'style'
    ? '移出风格参考'
    : referenceRole === 'content'
      ? '转为风格参考'
      : '加入风格参考'

  return (
    <ImageCard $primary={isPrimary} $selected={isSelected}>
      <ImageThumbButton type="button" onClick={() => onOpenPreview(document)} title={`预览：${document.title}`}>
        <ImageThumbFrame>
          <ImageBadgeRail>
            <ImageBadgeGroup>
              {referenceRole ? <ImageOverlayBadge $tone={isPrimary ? 'primary' : 'secondary'}>{formatImageReferenceRoleLabel(referenceRole)}</ImageOverlayBadge> : null}
            </ImageBadgeGroup>
            <ImageBadgeGroup>
              {typeof referenceWeight === 'number' && isSelected ? <ImageOverlayBadge $tone="neutral">权重 {Math.round(referenceWeight * 100)}%</ImageOverlayBadge> : null}
            </ImageBadgeGroup>
          </ImageBadgeRail>
          {thumbnailUrl ? (
            <ImageThumb src={thumbnailUrl} alt={document.title} loading="lazy" onError={() => setThumbFailed(true)} />
          ) : (
            <ImageFallback>
              <ImageOff size={18} />
              <span>缩略图加载失败</span>
            </ImageFallback>
          )}
        </ImageThumbFrame>
      </ImageThumbButton>
      <DocumentMain type="button" onClick={() => onOpenDocument(document)}>
        <DocumentTitle>{document.title}</DocumentTitle>
        <DocumentExcerpt>{document.originalName || document.previewText || '图片素材'}</DocumentExcerpt>
      </DocumentMain>
      <MetaRow>
        <MetaChip $accent>IMAGE</MetaChip>
        {referenceRole ? <MetaChip $accent>{formatImageCardRoleLabel(mode, referenceRole)}</MetaChip> : null}
        {isSelected ? <MetaChip $accent>{mode === 'image' ? '本轮参与生成' : '已加入本轮'}</MetaChip> : <MetaChip>可用素材</MetaChip>}
      </MetaRow>
      <WorkflowActionStack>
        {mode === 'image' ? (
          <>
            <WorkflowPrimaryActions $columns={2}>
              <WorkflowMainButton type="button" $tone="primary" $active={referenceRole === 'primary-style'} onClick={() => onSetPrimary(document)}>
                {referenceRole === 'primary-style' ? '当前主参考图' : '设为主参考图'}
              </WorkflowMainButton>
              <WorkflowMainButton
                type="button"
                $tone="secondary"
                $active={referenceRole === 'style'}
                onClick={() => {
                  if (referenceRole === 'style') {
                    onClearReference(document)
                    return
                  }
                  onSetStyleReference(document)
                }}
              >
                {imageStyleActionLabel}
              </WorkflowMainButton>
            </WorkflowPrimaryActions>
            <WorkflowSecondaryActions>
              <ActionButton type="button" onClick={() => onOpenPreview(document)}>
                预览
              </ActionButton>
              <SoftDangerButton type="button" onClick={() => onDelete(document)} title={`删除知识库资料：${document.title}`}>
                删除
              </SoftDangerButton>
            </WorkflowSecondaryActions>
          </>
        ) : (
          <WorkflowPrimaryActions $columns={2}>
            <WorkflowMainButton type="button" $tone="primary" $active={referenceRole === 'primary-style'} onClick={() => onSetPrimary(document)}>
              {referenceRole === 'primary-style' ? '当前主素材' : '设为主素材'}
            </WorkflowMainButton>
            <WorkflowMainButton type="button" $tone="secondary" $active={referenceRole === 'style'} onClick={() => onSetStyleReference(document)}>
              {referenceRole === 'style' ? '移出本轮' : '加入本轮'}
            </WorkflowMainButton>
          </WorkflowPrimaryActions>
        )}
        {mode !== 'image' ? (
          <WorkflowUtilityActions>
            <UtilityActionGroup>
              <ActionButton type="button" onClick={() => onOpenPreview(document)}>
                预览
              </ActionButton>
            </UtilityActionGroup>
            <SoftDangerButton type="button" onClick={() => onDelete(document)} title={`删除知识库资料：${document.title}`}>
              删除
            </SoftDangerButton>
          </WorkflowUtilityActions>
        ) : null}
        <WorkflowHint>
          {helperText}
        </WorkflowHint>
      </WorkflowActionStack>
    </ImageCard>
  )
}

const EmptyState = styled.div`
  border: 1px dashed #cfe0f1;
  border-radius: 14px;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f9ff 100%);
  padding: 14px;
  font-size: 12px;
  line-height: 1.7;
  color: #667d92;
`

const Footer = styled.div`
  padding: 10px 12px 12px;
  border-top: 1px solid #e3ebf3;
  background: rgba(255, 255, 255, 0.96);
  display: grid;
  gap: 8px;
`

const FooterActions = styled.div`
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
`

const FooterButton = styled.button`
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid #d8e2ed;
  background: #ffffff;
  color: #4b6278;
  font-size: 12px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  cursor: pointer;

  &:hover:not(:disabled) {
    background: #f4f8fc;
  }

  &:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
`

interface GenerationKnowledgeSidebarProps {
  onCollapse?: () => void
  embedded?: boolean
}

type MaterialFilter = 'all' | 'document' | 'image'

function matchesSearch(document: KnowledgeDocumentMeta, keyword: string): boolean {
  const normalized = keyword.trim().toLowerCase()
  if (!normalized) return true
  const haystack = [
    document.title,
    document.originalName,
    document.previewText,
    document.documentCategory,
    document.categoryDetail,
  ].join(' ').toLowerCase()
  return haystack.includes(normalized)
}

function getPriorityScore(
  mode: GenerationMode,
  document: KnowledgeDocumentMeta,
  selectedIds: Set<string>,
  currentTemplateId: string | null,
  primaryAssetId: string | null,
): number {
  if (mode === 'document') {
    return (document.id === currentTemplateId ? 1000 : 0)
      + (selectedIds.has(document.id) ? 400 : 0)
      + (isDocumentTemplateCandidate(document) ? 120 : 0)
  }
  if (mode === 'image') {
    return (document.id === primaryAssetId ? 1000 : 0)
      + (selectedIds.has(document.id) ? 420 : 0)
  }
  return (selectedIds.has(document.id) ? 500 : 0)
}

function formatDocumentType(document: KnowledgeDocumentMeta): string {
  return document.sourceType === 'image' ? 'IMAGE' : document.sourceType.toUpperCase()
}

export default function GenerationKnowledgeSidebar({ onCollapse, embedded = false }: GenerationKnowledgeSidebarProps) {
  const { currentMode } = useWorkspaceMode()
  const workbench = useGenerationWorkbench()
  const knowledge = useKnowledge()
  const { openKnowledgeDocumentPreview } = useDocumentEngineHostCommands()
  const { setCommitResult } = useFormalTemplateSession()
  const { setStatusMessage } = useDocument()
  const [panelWidth, setPanelWidth] = useState(300)
  const [searchText, setSearchText] = useState('')
  const [materialFilter, setMaterialFilter] = useState<MaterialFilter>('all')
  const [previewDocument, setPreviewDocument] = useState<PreviewableKnowledgeDocument | null>(null)
  const [previewFailed, setPreviewFailed] = useState(false)

  const modeOption = getGenerationModeOption(currentMode)
  const assetSelectedIdSet = useMemo(() => new Set(workbench.selectedAssetIds), [workbench.selectedAssetIds])
  const imageReferenceMap = useMemo(() => new Map(workbench.imageReferences.map((item) => [item.id, item])), [workbench.imageReferences])
  const imageSelectedIdSet = useMemo(() => new Set(workbench.imageReferences.map((item) => item.id)), [workbench.imageReferences])
  const selectedIdSet = useMemo(() => {
    if (currentMode === 'image') return imageSelectedIdSet
    return assetSelectedIdSet
  }, [assetSelectedIdSet, currentMode, imageSelectedIdSet])

  const visibleDocuments = useMemo(() => {
    return knowledge.documents
      .filter((document) => matchesGenerationCandidate(currentMode, document))
      .filter((document) => {
        if (materialFilter === 'all') return true
        if (materialFilter === 'image') return document.sourceType === 'image'
        return document.sourceType !== 'image'
      })
      .filter((document) => matchesSearch(document, searchText))
      .sort((left, right) => {
        const scoreDiff = getPriorityScore(currentMode, right, selectedIdSet, workbench.currentTemplateId, workbench.primaryAssetId)
          - getPriorityScore(currentMode, left, selectedIdSet, workbench.currentTemplateId, workbench.primaryAssetId)
        if (scoreDiff !== 0) return scoreDiff
        return String(right.importedAt || '').localeCompare(String(left.importedAt || ''))
      })
  }, [currentMode, knowledge.documents, materialFilter, searchText, selectedIdSet, workbench.currentTemplateId, workbench.primaryAssetId])

  const handleResize = (event: React.MouseEvent) => {
    event.preventDefault()
    const startX = event.clientX
    const startWidth = panelWidth
    const onMove = (moveEvent: MouseEvent) => {
      setPanelWidth(Math.max(280, Math.min(320, startWidth + moveEvent.clientX - startX)))
    }
    const onUp = () => {
      document.removeEventListener('mousemove', onMove)
      document.removeEventListener('mouseup', onUp)
    }
    document.addEventListener('mousemove', onMove)
    document.addEventListener('mouseup', onUp)
  }

  const handleImport = async () => {
    try {
      const result = await knowledge.importDocuments()
      const importedCount = result.imported.length
      const duplicateCount = result.duplicates.length
      setStatusMessage(importedCount > 0
        ? `已导入 ${importedCount} 份资料${duplicateCount > 0 ? `，跳过 ${duplicateCount} 份重复文件` : ''}`
        : duplicateCount > 0
          ? `本次没有新文件，已识别 ${duplicateCount} 份重复资料`
          : '本次没有导入新的资料')
    } catch (error) {
      setStatusMessage(error instanceof Error ? `导入资料失败：${error.message}` : '导入资料失败')
    }
  }

  const handleClearSelections = () => {
    if (currentMode === 'document') {
      if (knowledge.templateDocumentId) knowledge.setTemplateDocument(null)
      if (knowledge.referenceDocumentIds.length > 0) {
        knowledge.unselectReferenceDocuments(knowledge.referenceDocumentIds)
      }
      setCommitResult(null)
      workbench.clearCurrentResult()
      setStatusMessage('已清空文稿模式的模板与本轮资料')
      return
    }

    if (currentMode === 'image') {
      if (knowledge.styleImageDocumentIds.length > 0) {
        knowledge.unselectStyleImageDocuments(knowledge.styleImageDocumentIds)
      }
      workbench.clearCurrentSelections()
      workbench.clearCurrentResult()
      setStatusMessage('已清空图片模式的参考图选择')
      return
    }

    workbench.clearCurrentSelections()
    workbench.clearCurrentResult()
    setStatusMessage('已清空 PPT 模式的本轮素材')
  }

  const handleOpenDocument = async (document: KnowledgeDocumentMeta) => {
    try {
      await knowledge.openDocument(document.id)
      await openKnowledgeDocumentPreview(document.id)
      setStatusMessage(`已只读打开资料：${document.title}`)
    } catch (error) {
      setStatusMessage(error instanceof Error ? `打开资料失败：${error.message}` : '打开资料失败')
    }
  }

  const handleOpenPreview = (document: KnowledgeDocumentMeta) => {
    setPreviewFailed(false)
    setPreviewDocument(document as PreviewableKnowledgeDocument)
  }

  const handleDeleteDocument = async (document: KnowledgeDocumentMeta) => {
    const confirmed = window.confirm(`确认从知识库移除“${document.title}”吗？`)
    if (!confirmed) return

    try {
      await knowledge.deleteDocument(document.id)
      workbench.removeDocumentFromSessions(document.id)
      setStatusMessage(`已从知识库移除：${document.title}`)
    } catch (error) {
      const message = error instanceof Error ? error.message : '未知错误'
      setStatusMessage(`删除失败：${message}`)
      window.alert(`删除“${document.title}”失败：${message}`)
    }
  }

  const handleDocumentAction = (document: KnowledgeDocumentMeta) => {
    if (currentMode === 'document') {
      if (isDocumentTemplateCandidate(document)) {
        knowledge.setTemplateDocument(document.id)
        if (knowledge.referenceDocumentIds.includes(document.id)) {
          knowledge.unselectReferenceDocuments([document.id])
        }
        setStatusMessage(`已将“${document.title}”设为当前模板`)
      }
      return
    }

    if (currentMode === 'image') {
      if (!isImageMaterialCandidate(document)) {
        setStatusMessage(`“${document.title}”当前不能作为参考图`)
        return
      }
      if (!knowledge.styleImageDocumentIds.includes(document.id)) {
        knowledge.selectStyleImageDocuments([document.id])
      }
      workbench.setImageReferenceRole(document.id, 'primary-style')
      setStatusMessage(`已将“${document.title}”设为主参考图`)
      return
    }

    if (!workbench.selectedAssetIds.includes(document.id)) {
      workbench.toggleSelectedAsset(document.id)
    }
    workbench.setPrimaryAssetId(document.id)
    setStatusMessage(`已将“${document.title}”标记为 PPT 主素材`)
  }

  const handleToggleSelection = (document: KnowledgeDocumentMeta) => {
    if (currentMode === 'document') {
      if (!isDocumentMaterialCandidate(document)) {
        setStatusMessage(`“${document.title}”当前不支持加入文稿资料池`)
        return
      }
      if (document.id === knowledge.templateDocumentId) {
        setStatusMessage('当前模板不会重复计入本轮资料，请改选其他模板后再加入')
        return
      }
      knowledge.toggleReferenceDocument(document.id)
      setStatusMessage(selectedIdSet.has(document.id) ? `已将“${document.title}”移出本轮资料` : `已将“${document.title}”加入本轮资料`)
      return
    }

    if (currentMode === 'image') {
      if (!isImageMaterialCandidate(document)) {
        setStatusMessage(`“${document.title}”当前不支持作为风格参考`)
        return
      }
      const currentRole = imageReferenceMap.get(document.id)?.role || null
      if (currentRole === 'style') {
        knowledge.unselectStyleImageDocuments([document.id])
        workbench.setImageReferenceRole(document.id, null)
        setStatusMessage(`已移出风格参考：${document.title}`)
        return
      }
      if (!knowledge.styleImageDocumentIds.includes(document.id)) {
        knowledge.selectStyleImageDocuments([document.id])
      }
      workbench.setImageReferenceRole(document.id, 'style')
      setStatusMessage(`已加入风格参考：${document.title}`)
      return
    }

    if (!isPptMaterialCandidate(document)) {
      setStatusMessage(`“${document.title}”当前不能加入 PPT 素材池`)
      return
    }
    if (workbench.primaryAssetId === document.id) {
      setStatusMessage('当前主素材默认参与本轮，请先将其他素材设为主素材后再移出')
      return
    }
    workbench.toggleSelectedAsset(document.id)
    setStatusMessage(selectedIdSet.has(document.id) ? `已移出 PPT 素材：${document.title}` : `已加入 PPT 素材：${document.title}`)
  }

  const handleSetImageRole = (document: KnowledgeDocumentMeta, role: ImageReferenceRole | null) => {
    if (!isImageMaterialCandidate(document)) {
      setStatusMessage(`“${document.title}”当前不能作为图片参考图`)
      return
    }

    if (!role) {
      if (knowledge.styleImageDocumentIds.includes(document.id)) {
        knowledge.unselectStyleImageDocuments([document.id])
      }
      workbench.setImageReferenceRole(document.id, null)
      setStatusMessage(`已取消参考图：${document.title}`)
      return
    }

    if (!knowledge.styleImageDocumentIds.includes(document.id)) {
      knowledge.selectStyleImageDocuments([document.id])
    }
    workbench.setImageReferenceRole(document.id, role)
    setStatusMessage(`已将“${document.title}”设为${formatImageReferenceRoleLabel(role)}`)
  }

  const renderStandardDocumentCard = (document: KnowledgeDocumentMeta) => {
    const isPrimary = currentMode === 'document'
      ? document.id === workbench.currentTemplateId
      : document.id === workbench.primaryAssetId
    const isSelected = selectedIdSet.has(document.id)
    const showPrimaryAction = currentMode === 'document'
      ? isDocumentTemplateCandidate(document)
      : isPptMaterialCandidate(document)
    const showSecondaryAction = currentMode === 'document'
      ? isDocumentMaterialCandidate(document)
      : isPptMaterialCandidate(document)
    const disableSecondary = currentMode === 'ppt' && isPrimary

    return (
      <DocumentCard key={document.id} $active={isPrimary || isSelected}>
        <DocumentMain type="button" onClick={() => void handleOpenDocument(document)}>
          <DocumentTitle>{document.title}</DocumentTitle>
          <DocumentExcerpt>{document.previewText || document.originalName}</DocumentExcerpt>
        </DocumentMain>
        <MetaRow>
          <MetaChip $accent={isPrimary}>{formatDocumentType(document)}</MetaChip>
          {document.documentCategory ? <MetaChip>{document.documentCategory}</MetaChip> : null}
          {isPrimary ? <MetaChip $accent>{currentMode === 'document' ? '当前模板' : '主素材'}</MetaChip> : null}
          {isSelected ? <MetaChip $accent>{currentMode === 'ppt' ? '本轮素材' : '已加入本轮'}</MetaChip> : null}
        </MetaRow>
        <ActionRow>
          {showPrimaryAction ? (
            <ActionButton type="button" $primary={isPrimary} onClick={() => handleDocumentAction(document)}>
              {currentMode === 'document'
                ? isPrimary ? '当前模板' : '设为模板'
                  : isPrimary ? '当前主素材' : '设为主素材'}
            </ActionButton>
          ) : null}
          {showSecondaryAction ? (
            <ActionButton type="button" onClick={() => handleToggleSelection(document)} disabled={disableSecondary}>
              {disableSecondary ? '主素材默认参与' : currentMode === 'document' ? (isSelected ? '移出参考' : '加入参考') : (isSelected ? '移出本轮' : '加入参考')}
            </ActionButton>
          ) : null}
          <SoftDangerButton type="button" onClick={() => void handleDeleteDocument(document)} title={`删除知识库资料：${document.title}`}>
            删除
          </SoftDangerButton>
        </ActionRow>
      </DocumentCard>
    )
  }

  const previewImageUrl = previewDocument ? toDisplayUrl(resolveKnowledgeOriginalPath(knowledge.info?.rootPath, previewDocument)) : ''
  const previewImageReference = previewDocument ? imageReferenceMap.get(previewDocument.id) || null : null
  const isImageMode = currentMode === 'image'

  return (
    <Panel $width={panelWidth} $locked={isImageMode} $embedded={embedded} data-testid="generation-knowledge-sidebar">
      {!isImageMode && !embedded ? <ResizeHandle onMouseDown={handleResize} /> : null}
      <Header>
        <HeaderRow>
          <HeaderCopy>
            <HeaderTitle><BookOpen size={14} /> 知识库</HeaderTitle>
            <HeaderDesc>
              {currentMode === 'document'
                ? '统一浏览文稿资料，默认勾选动作为加入参考，需要时可直接设为模板。'
                : currentMode === 'ppt'
                  ? '统一浏览 PPT 文档与图片素材，先加入本轮，再指定其中一项作为主素材。'
                  : '统一浏览图片素材，先设定主参考图，再补充风格或内容参考。'}
            </HeaderDesc>
          </HeaderCopy>
          <HeaderActions>
            {onCollapse ? (
              <IconButton type="button" onClick={onCollapse} title="收起左栏">
                <PanelLeftClose size={14} />
              </IconButton>
            ) : null}
          </HeaderActions>
        </HeaderRow>
        <SearchWrap>
          <Search size={14} color="#708396" />
          <SearchInput
            value={searchText}
            onChange={(event) => setSearchText(event.target.value)}
            placeholder={`搜索${modeOption.label}资料...`}
          />
        </SearchWrap>
        {currentMode === 'ppt' ? (
          <ToolbarRow>
            <ToolbarCluster>
              <ToolbarLabel>类型</ToolbarLabel>
              <ToolbarSelect value={materialFilter} onChange={(event) => setMaterialFilter(event.target.value as MaterialFilter)}>
                <option value="all">全部类型</option>
                <option value="document">文档</option>
                <option value="image">图片</option>
              </ToolbarSelect>
            </ToolbarCluster>
            <ToolbarLabel>{visibleDocuments.length} 项可见</ToolbarLabel>
          </ToolbarRow>
        ) : null}
      </Header>

      <Content $imageMode={isImageMode}>
        {currentMode === 'image' ? (
          <Section $stretch>
            <SectionHead>
              <SectionTitle>图片素材</SectionTitle>
              <SectionMeta>{visibleDocuments.length} 张</SectionMeta>
            </SectionHead>
            {visibleDocuments.length > 0 ? (
              <CardList $scrollable $twoColumn={embedded}>
                {visibleDocuments.map((document) => {
                  const reference = imageReferenceMap.get(document.id) || null
                  return (
                    <ImageMaterialCard
                      key={document.id}
                      document={document as PreviewableKnowledgeDocument}
                      mode="image"
                      rootPath={knowledge.info?.rootPath}
                      referenceRole={reference?.role || null}
                      referenceWeight={reference?.weight}
                      onOpenDocument={(item) => { void handleOpenDocument(item) }}
                      onOpenPreview={handleOpenPreview}
                      onSetPrimary={(item) => handleSetImageRole(item, 'primary-style')}
                      onSetStyleReference={(item) => handleSetImageRole(item, 'style')}
                      onSetContentReference={(item) => handleSetImageRole(item, 'content')}
                      onClearReference={(item) => handleSetImageRole(item, null)}
                      onDelete={(item) => { void handleDeleteDocument(item) }}
                    />
                  )
                })}
              </CardList>
            ) : (
              <EmptyState>当前筛选条件下没有图片素材。可以导入新图片，或调整搜索条件后再挑选参考图。</EmptyState>
            )}
          </Section>
        ) : currentMode === 'ppt' ? (
          <Section>
            <SectionHead>
              <SectionTitle>PPT 素材</SectionTitle>
              <SectionMeta>{visibleDocuments.length} 份</SectionMeta>
            </SectionHead>
            {visibleDocuments.length > 0 ? (
              <CardList $twoColumn={embedded}>
                {visibleDocuments.map((document) => (
                  document.sourceType === 'image' ? (
                    <ImageMaterialCard
                      key={document.id}
                      document={document as PreviewableKnowledgeDocument}
                      mode="ppt"
                      rootPath={knowledge.info?.rootPath}
                      referenceRole={document.id === workbench.primaryAssetId ? 'primary-style' : selectedIdSet.has(document.id) ? 'style' : null}
                      onOpenDocument={(item) => { void handleOpenDocument(item) }}
                      onOpenPreview={handleOpenPreview}
                      onSetPrimary={handleDocumentAction}
                      onSetStyleReference={handleToggleSelection}
                      onSetContentReference={handleToggleSelection}
                      onClearReference={handleToggleSelection}
                      onDelete={(item) => { void handleDeleteDocument(item) }}
                    />
                  ) : renderStandardDocumentCard(document)
                ))}
              </CardList>
            ) : (
              <EmptyState>当前筛选条件下没有 PPT 候选资料。可以导入新文件，或调整搜索条件后继续挑选。</EmptyState>
            )}
          </Section>
        ) : (
          <Section>
            <SectionHead>
              <SectionTitle>可用资料</SectionTitle>
              <SectionMeta>{visibleDocuments.length} 份</SectionMeta>
            </SectionHead>
            {visibleDocuments.length > 0 ? (
              <CardList $twoColumn={embedded}>
                {visibleDocuments.map((document) => renderStandardDocumentCard(document))}
              </CardList>
            ) : (
              <EmptyState>当前筛选条件下没有可用资料。可以导入新文件，或切换到底部输入区直接描述本轮生成任务。</EmptyState>
            )}
          </Section>
        )}
      </Content>

      <Footer>
        <FooterActions>
          <FooterButton type="button" onClick={() => void handleImport()} disabled={knowledge.importing}>
            <Upload size={14} /> {knowledge.importing ? '导入中' : '导入资料'}
          </FooterButton>
          <FooterButton type="button" onClick={() => void knowledge.refresh()} disabled={knowledge.loading}>
            <RefreshCw size={14} /> 刷新
          </FooterButton>
          <FooterButton type="button" onClick={handleClearSelections}>
            {currentMode === 'document' ? <BookOpen size={14} /> : currentMode === 'image' ? <FileImage size={14} /> : <FileStack size={14} />} 清空本轮
          </FooterButton>
        </FooterActions>
      </Footer>

      {previewDocument ? (
        <PreviewBackdrop onClick={() => setPreviewDocument(null)}>
          <PreviewDialog onClick={(event) => event.stopPropagation()}>
            <PreviewHeader>
              <PreviewTitleWrap>
                <PreviewTitle>{previewDocument.title}</PreviewTitle>
                <PreviewSubtitle>
                  {currentMode === 'image'
                    ? previewImageReference
                      ? `${formatImageReferenceRoleLabel(previewImageReference.role)}${typeof previewImageReference.weight === 'number' ? ` · 权重 ${Math.round(previewImageReference.weight * 100)}%` : ''}`
                      : '可用图片素材'
                    : previewDocument.id === workbench.primaryAssetId
                      ? '当前主素材'
                      : selectedIdSet.has(previewDocument.id)
                        ? '当前已选本轮素材'
                        : '可用图片素材'}
                  {' · '}
                  {previewDocument.originalName || '图片预览'}
                </PreviewSubtitle>
              </PreviewTitleWrap>
              <IconButton type="button" onClick={() => setPreviewDocument(null)} title="关闭预览">
                <X size={14} />
              </IconButton>
            </PreviewHeader>
            <PreviewBody>
              {previewImageUrl && !previewFailed ? (
                <PreviewImage src={previewImageUrl} alt={previewDocument.title} onError={() => setPreviewFailed(true)} />
              ) : (
                <ImageFallback>
                  <ImageOff size={20} />
                  <span>原图预览加载失败</span>
                </ImageFallback>
              )}
            </PreviewBody>
          </PreviewDialog>
        </PreviewBackdrop>
      ) : null}
    </Panel>
  )
}