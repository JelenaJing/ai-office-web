{
  "appId": "com.aioffice.desktop.v3",
  "productName": "AI-Office 3.0",
  "directories": {
    "buildResources": "build",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "asar": true,
  "extraResources": [
    {
      "from": "build/vosk-models",
      "to": "vosk-models",
      "filter": ["**/*"]
    },
    {
      "from": "electron/main/data",
      "to": "data",
      "filter": ["**/*"]
    },
    {
      "from": "docs/photoes",
      "to": "data/essay-style-presets",
      "filter": ["**/*"]
    },
    {
      "from": "../introduction-remake-app/dist",
      "to": "introduction-remake-app/dist",
      "filter": ["**/*"]
    },
    {
      "from": "../introduction-remake-app/electron/main/data/tier1_journals.json",
      "to": "data/tier1_journals.json"
    },
    {
      "from": "../merged-plot-agent",
      "to": "merged-plot-agent",
      "filter": [
        "api/**/*",
        "ai_agent/**/*",
        "config/**/*",
        "data_loader/**/*",
        "plotters/**/*",
        "templates/**/*",
        "local_bridge.py",
        "requirements.txt",
        "setup.R",
        "setup_env.sh",
        "README.md"
      ]
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ]
  },
  "portable": {
    "artifactName": "AI-Office-3.0-${version}-Portable.${ext}"
  }
}