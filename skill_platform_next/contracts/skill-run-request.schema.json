{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-office.local/contracts/skill-run-request.schema.json",
  "title": "SkillRunRequest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "skill_id",
    "operation",
    "workspace_id",
    "input"
  ],
  "properties": {
    "schema_version": {
      "const": "ai-office-skill-run-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "skill_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "user_context": {
      "type": "object",
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "required": ["source_artifacts"],
      "properties": {
        "source_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact_id"],
            "properties": {
              "artifact_id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

