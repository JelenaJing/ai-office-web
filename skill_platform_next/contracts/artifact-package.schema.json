{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-office.local/contracts/artifact-package.schema.json",
  "title": "ArtifactPackage",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "skill_id",
    "status",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "ai-office-artifact-package-v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "skill_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "cancelled",
        "need_user_input"
      ]
    },
    "primary_artifact_id": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "type", "title"],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "mime_type": {
            "type": "string"
          },
          "content": {
            "type": ["object", "string", "array", "null"]
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}

